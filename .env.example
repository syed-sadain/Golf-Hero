# ── GolfHero Environment Variables ──────────────────────────────
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control

# Flask
SECRET_KEY=your-very-secret-random-key-here
FLASK_DEBUG=0

# PostgreSQL — Heroku sets DATABASE_URL automatically
# For local development use your local Postgres connection string:
DATABASE_URL=postgresql://postgres:password@localhost:5432/golfhero

# Stripe (get from https://dashboard.stripe.com/apikeys)
STRIPE_PUBLIC_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
MONTHLY_PRICE_ID=price_...
YEARLY_PRICE_ID=price_...
